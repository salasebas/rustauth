# RustAuth backend-reference — copy to .env and adjust for local development.
# RUSTAUTH_* is preferred; RUSTAUTH_* is accepted as a legacy fallback.

RUSTAUTH_SECRET=dev-secret-at-least-32-characters-long!!
RUSTAUTH_HOST=127.0.0.1
RUSTAUTH_PORT=3000
RUSTAUTH_AUTH_BASE_PATH=/api/auth
RUSTAUTH_BASE_URL=http://127.0.0.1:3000/api/auth
RUST_ENV=development
RUSTAUTH_TRUSTED_ORIGINS=http://127.0.0.1:3000
DATABASE_URL=postgres://user:password@127.0.0.1:5432/rustauth

# Optional telemetry (enable rustauth/telemetry feature on the example crate)
# RUSTAUTH_TELEMETRY=1

# Cognito (pattern 3 — pool metadata + OAuth client)
COGNITO_DOMAIN=rustauth-reference.auth.example.com
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_rustauth_reference
COGNITO_CLIENT_ID=stub-COGNITO-client-id
COGNITO_CLIENT_SECRET=stub-COGNITO-client-secret

# Provider-specific options (pattern 4 — advanced::*)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_HD=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_APP_BUNDLE_ID=
APPLE_AUDIENCE=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CONFIG_ID=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ISSUER=

PAYBIN_CLIENT_ID=
PAYBIN_CLIENT_SECRET=
PAYBIN_ISSUER=

# TikTok uses CLIENT_KEY in addition to CLIENT_ID / CLIENT_SECRET
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=

# Catalog providers (pattern 1) — set real values or rely on dev stubs
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
