# Stripe test-mode smoke — copy to repo root `.env` (recommended) or your server’s env file.
# Never commit real secrets. See SMOKE.md for the full checklist.

# --- Stripe (test mode) ---
# Secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Optional for apps you run yourself. The smoke server (`openauth-example-stripe-smoke`)
# starts `stripe listen` and does not read STRIPE_WEBHOOK_SECRET from .env.
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs from Dashboard → Products (test mode). Must match plan names in your OpenAuth config.
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_TEAM_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_TEAM_YEARLY=price_REPLACE_ME
STRIPE_PRICE_TEAM_SEAT=price_REPLACE_ME

# --- OpenAuth server (your harness, not read by the crate directly) ---
OPENAUTH_SECRET=secret-a-at-least-32-chars-long!!
OPENAUTH_BASE_URL=http://127.0.0.1:3000/api/auth

# Optional: session cookie value for curl steps in scripts/stripe-smoke.sh
# OPENAUTH_SESSION_COOKIE=openauth.session_token=...

# Optional: database when your server uses Postgres/MySQL instead of SQLite
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/openauth
